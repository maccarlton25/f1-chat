# AI provider — needed for the agent to generate responses.
#
# Option A: Vercel AI Gateway (recommended for Vercel deployments)
# Get a key at https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=your_gateway_key_here
#
# Option B: Direct provider (e.g. Anthropic)
# If you switch agent.ts to use a direct provider model like
# anthropic("claude-sonnet-4.6"), set this instead:
# ANTHROPIC_API_KEY=your_anthropic_key_here
#
# Option C: Vercel OIDC (automatic when deployed on Vercel)
# Run `vercel link` and eve will pull a token automatically.
# No env var needed — eve reads VERCEL_OIDC_TOKEN at runtime.
